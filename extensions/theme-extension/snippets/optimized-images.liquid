<script>
document.addEventListener("DOMContentLoaded", () => {
  {% if product %}
    const optimizedMap = {{ product.metafields.optimized_images.opUrl | default: '' | json }};
    console.log("Optimized Map:", optimizedMap);
    if (optimizedMap && typeof optimizedMap === "object") {
      document.querySelectorAll("img[data-media-id]").forEach(img => {
        const mediaId = img.dataset.mediaId;
        if (mediaId && optimizedMap[mediaId]) {
          img.src = optimizedMap[mediaId];
          if (img.srcset) {
            img.srcset = optimizedMap[mediaId];
          }
        }
      });
    }
  {% endif %}
});
</script>
