{% if product %}
<script>
document.addEventListener("DOMContentLoaded", () => {
  const optimizedUrl = "{{ product.metafields.optimized_images.opUrl | escape }}";

  if (!optimizedUrl) {
    console.log("ko co optimized URL:", "{{ product.title | escape }}");
    return;
  }

  console.log("Optimized URL:", "{{ product.title | escape }}", optimizedUrl);

  const imgs = document.querySelectorAll(".product__media img");
  imgs.forEach(img => {
    img.src = optimizedUrl;
    if (img.hasAttribute("srcset")) {
      img.srcset = optimizedUrl;
      console.log("img.srcset:",  img.srcset);
    }
  });
});
</script>
{% endif %}

